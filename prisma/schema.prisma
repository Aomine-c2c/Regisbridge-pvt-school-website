generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums (Simulated for SQLite) ---
// Role: 'ADMIN', 'TEACHER', 'STUDENT', 'PARENT', 'STAFF'
// UserStatus: 'ACTIVE', 'INACTIVE', 'SUSPENDED'
// AttendanceStatus: 'PRESENT', 'ABSENT', 'LATE', 'EXCUSED'
// AssignmentType: 'HOMEWORK', 'PROJECT', 'QUIZ', 'ESSAY'
// AssignmentStatus: 'DRAFT', 'PUBLISHED', 'ARCHIVED'
// SubmissionStatus: 'PENDING', 'SUBMITTED', 'GRADED', 'LATE'
// FeeType: 'TUITION', 'TRANSPORT', 'LIBRARY', 'HOSTEL', 'EXAM', 'OTHER'
// PaymentStatus: 'PENDING', 'PARTIAL', 'PAID', 'OVERDUE'
// PaymentMethod: 'CASH', 'card', 'BANK_TRANSFER', 'CHECK', 'ONLINE'
// Gender: 'MALE', 'FEMALE', 'OTHER'

model User {
  id       String  @id @default(cuid())
  tenantId String? // Make optional initially for migration
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  email       String
  password    String
  firstName   String
  lastName    String
  role        String    @default("STUDENT") // Enum: Role
  phoneNumber String?
  status      String    @default("ACTIVE") // Enum: UserStatus
  lastLoginAt DateTime?

  // JSON Blobs removed in favor of relational permissions if needed, 
  // or kept simple for now as roles cover most cases.

  // Relations
  student        Student?
  teacherProfile TeacherProfile?
  parentProfile  ParentProfile?
  staffProfile   StaffProfile?

  refreshTokens    RefreshToken[]
  documents        Document[]
  notifications    Notification[]
  conversationParticipations ConversationParticipant[]
  sentMessages             Message[] 
  readReceipts             MessageReadStatus[]

  auditLogs        AuditLog[]

  // Enterprise RBAC
  roleId           String?
  userRole         Role?          @relation(fields: [roleId], references: [id])
  customPermissions UserPermission[]

  invigilatedExams ExamSchedule[] // Added for Exam Invigilation
  gradedSubmissions AssignmentSubmission[] @relation("SubmissionGrader")
  assignmentsCreated Assignment[]           @relation("AssignmentCreator")
  permissions       String? // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, email])
  @@index([role])
  @@index([tenantId])
  @@index([tenantId, role, lastName])
}

model Tenant {
  id           String  @id @default(uuid())
  name         String
  slug         String  @unique // Subdomain
  customDomain String? @unique

  logoUrl        String?
  primaryColor   String? @default("#0f172a")
  secondaryColor String? @default("#3b82f6")
  faviconUrl     String?
  uiConfig       String? @default("{}") // JSON string for customized UI layout

  gradingScales  GradingScale[]

  features TenantFeatures?

  users            User[]
  academicYears    AcademicYear[]
  classes          Class[]
  students         Student[]
  subjects         Subject[]
  term             Term[]
  grades           Grade[]
  attendance       Attendance[]
  assignments      Assignment[]
  submissions      AssignmentSubmission[]
  timetablePeriods TimetablePeriod[]
  auditLogs        AuditLog[]
  conversations    Conversation[]
  roles            Role[]
  aiInsights       AiInsight[]
  feePayments      FeePayment[]
  newsArticles     NewsArticle[]
  events           Event[]
  // Add other relations as we migrate them

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model TenantFeatures {
  id       String @id @default(uuid())
  tenantId String @unique
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  enableFinance   Boolean @default(true)
  enableHostel    Boolean @default(false)
  enableTransport Boolean @default(false)
  enableLibrary   Boolean @default(false)
  enableHR        Boolean @default(true)
  enableEvents    Boolean @default(true)
  enableBlog      Boolean @default(true)
}

model GradingScale {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  name      String   // e.g., "GPA 4.0", "Percentage", "Letter Grade"
  
  // JSON string for definition
  // e.g., [{ "label": "A", "min": 90, "max": 100, "gpa": 4.0 }, ...]
  definition String 

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- Academic Structure ---

model AcademicYear {
  id        String   @id @default(cuid())
  tenantId  String?
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])
  name      String   @unique // e.g., "2023-2024"
  startDate DateTime
  endDate   DateTime
  current   Boolean  @default(false)

  terms   Term[]
  classes Class[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Term {
  id             String       @id @default(cuid())
  tenantId       String?
  tenant         Tenant?      @relation(fields: [tenantId], references: [id])
  name           String // "Term 1", "Semester A"
  startDate      DateTime
  endDate        DateTime
  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  grades        Grade[]
  attendance    Attendance[]
  feeStructures FeeStructure[]
  examSessions  ExamSession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([academicYearId, name])
}

model Class {
  id         String  @id @default(cuid())
  tenantId   String?
  tenant     Tenant? @relation(fields: [tenantId], references: [id])
  name       String // e.g. "10-A"
  gradeLevel String // e.g. "10"
  grade      String? // Added for compatibility
  section    String? // e.g. "A"
  classSchedules ClassSchedule[]

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  classTeacherId String?
  classTeacher   TeacherProfile? @relation(fields: [classTeacherId], references: [id])

  students  Student[]
  timetable TimetablePeriod[]
  attendanceRecords Attendance[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, academicYearId])
}

model Subject {
  id          String  @id @default(cuid())
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])
  name        String
  code        String  @unique
  description String?

  teachers    TeacherSubject[]
  assignments Assignment[]
  timetable   TimetablePeriod[]
  grades      Grade[]
  exams       ExamSchedule[]
  classSchedules ClassSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- User Profiles ---

model Student {
  id       String  @id @default(cuid())
  tenantId String?
  tenant   Tenant? @relation(fields: [tenantId], references: [id])
  userId   String  @unique
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  admissionIdentifier String   @unique // admission number / roll number
  rollNumber          String?  @unique // alias for admissionIdentifier
  currentGrade        String?  // Added for route compatibility
  section             String?  // Added for route compatibility
  dateOfBirth         DateTime?
  enrollmentDate      DateTime @default(now())
  parentName          String?
  parentEmail         String?
  parentPhone         String?
  medicalNotes        String?
  gender              String // Enum: Gender
  bloodGroup          String?
  address             String?
  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  parents ParentStudent[]

  attendance    Attendance[]
  grades        Grade[]
  submissions   AssignmentSubmission[]
  feePayments   FeePayment[]
  libraryIssues LibraryIssue[]
  hostelBed     HostelBed?
  healthRecord  HealthRecord?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentProfile {
  id         String  @id @default(cuid())
  userId     String  @unique
  user       User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  occupation String?

  students ParentStudent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ParentStudent {
  parentId     String
  parent       ParentProfile @relation(fields: [parentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)
  relationship String // 'FATHER', 'MOTHER', 'GUARDIAN'

  @@id([parentId, studentId])
}

model TeacherProfile {
  id             String  @id @default(cuid())
  userId         String  @unique
  user           User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId     String  @unique
  specialization String?
  qualification  String?

  classesManaged Class[]
  subjectsTaught TeacherSubject[]
  classSchedules ClassSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeacherSubject {
  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject        @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@id([teacherId, subjectId])
}

model StaffProfile {
  id          String @id @default(cuid())
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId  String @unique
  department  String
  designation String

  payrolls Payroll[]
  leaves   Leave[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Academic Modules ---

model Attendance {
  id        String  @id @default(cuid())
  tenantId  String?
  tenant    Tenant? @relation(fields: [tenantId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  date    DateTime
  status  String // Enum: AttendanceStatus
  remarks String?

  termId String?
  term   Term?   @relation(fields: [termId], references: [id])

  recordedById String?

  classId String?
  class   Class?  @relation(fields: [classId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([date])
  @@index([classId, date])
}

model Grade {
  id        String  @id @default(cuid())
  studentId String
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  termId    String
  term      Term    @relation(fields: [termId], references: [id], onDelete: Cascade)
  tenantId  String?
  tenant    Tenant? @relation(fields: [tenantId], references: [id])

  assessmentType String // 'EXAM', 'TEST', 'ASSIGNMENT', 'PROJECT'
  score          Float
  maxScore       Float
  weightage      Float   @default(100)
  remarks        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Assignment {
  id          String  @id @default(cuid())
  title       String
  description String?
  subjectId   String
  subject     Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  tenantId    String?
  tenant      Tenant? @relation(fields: [tenantId], references: [id])

  dueDate  DateTime
  maxScore Int
  type     String // Enum: AssignmentType
  status   String   @default("DRAFT") // Enum: AssignmentStatus

  gradeLevel String?
  createdBy  String?
  creator    User?   @relation("AssignmentCreator", fields: [createdBy], references: [id])

  submissions AssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId, status, dueDate])
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  tenantId     String?
  tenant       Tenant?    @relation(fields: [tenantId], references: [id])
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  content   String?
  filePath  String?
  fileUrl   String? // Added for compatibility
  
  submittedAt DateTime @default(now())

  score      Float?
  remarks    String?
  gradedById String?
  gradedBy   User?   @relation("SubmissionGrader", fields: [gradedById], references: [id])
  status     String  @default("SUBMITTED") // SUBMITTED, GRADED, REJECTED
  gradedAt   DateTime?

  @@unique([assignmentId, studentId])
  documents    Document[]
}

model TimetablePeriod {
  id        String  @id @default(cuid())
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  tenantId  String?
  tenant    Tenant? @relation(fields: [tenantId], references: [id])

  dayOfWeek Int // 1 (Mon) - 7 (Sun)
  startTime String // HH:mm
  endTime   String // HH:mm
  room      String?

  @@index([classId, dayOfWeek])
}

// --- Finance Module ---

model FeeStructure {
  id       String @id @default(cuid())
  name     String // "Grade 10 Tuition"
  amount   Float
  currency String @default("USD")
  termId   String
  term     Term   @relation(fields: [termId], references: [id])

  dueDate DateTime

  // Could apply to specific Grade Levels or Classes
  // Simplified for now

  feePayments FeePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FeePayment {
  id             String        @id @default(cuid())
  studentId      String
  student        Student       @relation(fields: [studentId], references: [id])
  feeStructureId String?
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])

  tenantId      String?
  tenant        Tenant?       @relation(fields: [tenantId], references: [id])

  amountPaid    Float
  paymentDate   DateTime @default(now())
  method        String // Enum: PaymentMethod
  transactionId String?  @unique
  status        String // Enum: PaymentStatus

  recordedBy String? // User ID of accountant

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, status, paymentDate])
}

model FinancialTransaction {
  id          String   @id @default(cuid())
  type        String // 'INCOME', 'EXPENSE'
  category    String
  amount      Float
  description String?
  date        DateTime

  recordedBy String // User ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([date])
  @@index([type])
}

// --- HR & Payroll ---

model Leave {
  id         String       @id @default(cuid())
  staffId    String
  staff      StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type       String // 'SICK', 'CASUAL'
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String       @default("PENDING")
  approvedBy String? // User ID

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payroll {
  id      String       @id @default(cuid())
  staffId String
  staff   StaffProfile @relation(fields: [staffId], references: [id])
  month   Int
  year    Int

  basicSalary Float
  allowances  Float
  deductions  Float
  netSalary   Float

  status      String    @default("DRAFT")
  paymentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([staffId, month, year])
}

// --- Library & Assets ---

model Book {
  id     String  @id @default(cuid())
  title  String
  author String
  isbn   String? @unique
  copies Int     @default(1)

  issues LibraryIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LibraryIssue {
  id        String  @id @default(cuid())
  bookId    String
  book      Book    @relation(fields: [bookId], references: [id])
  studentId String
  student   Student @relation(fields: [studentId], references: [id])

  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String    @default("ISSUED") // 'ISSUED', 'RETURNED', 'OVERDUE'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Hostel ---

model HostelBlock {
  id        String       @id @default(cuid())
  name      String       @unique
  type      String?
  rooms     HostelRoom[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model HostelRoom {
  id         String      @id @default(cuid())
  roomNumber String
  capacity   Int
  floor      Int?
  blockId    String
  block      HostelBlock @relation(fields: [blockId], references: [id])
  beds       HostelBed[]
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt

  @@unique([blockId, roomNumber])
}

model HostelBed {
  id        String     @id @default(cuid())
  bedNumber String
  roomId    String
  room      HostelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  studentId String?    @unique
  student   Student?   @relation(fields: [studentId], references: [id])
  status    String     @default("VACANT")
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

// --- Transport ---

model Vehicle {
  id                 String   @id @default(uuid())
  registrationNumber String   @unique
  capacity           Int
  model              String?
  driverName         String?
  driverPhone        String?
  status             String   @default("ACTIVE")
  trips              Trip[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Route {
  id            String   @id @default(uuid())
  name          String
  startLocation String
  endLocation   String
  stops         String? // JSON string
  schedule      String?
  distance      Float?
  trips         Trip[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Trip {
  id        String   @id @default(uuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
  routeId   String
  route     Route    @relation(fields: [routeId], references: [id])
  date      DateTime
  driverId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- System ---

model Notification {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title   String
  message String
  read    Boolean @default(false)
  type    String // 'INFO', 'WARNING', 'ALERT'
  link    String?

  createdAt DateTime @default(now())
}


model Document {
  id       String @id @default(cuid())
  filename String
  url      String
  mimeType String
  size     Int

  uploadedById String
  uploadedBy   User   @relation(fields: [uploadedById], references: [id])

  submissionId String?
  submission   AssignmentSubmission? @relation(fields: [submissionId], references: [id])

  createdAt DateTime @default(now())
}

model ExamSession {
  id     String @id @default(cuid())
  name   String
  termId String
  term   Term   @relation(fields: [termId], references: [id])

  startDate DateTime
  endDate   DateTime
  status    String   @default("UPCOMING")

  schedules ExamSchedule[]
}

model ExamSchedule {
  id        String      @id @default(cuid())
  sessionId String
  session   ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject     @relation(fields: [subjectId], references: [id])

  date        DateTime
  startTime   String
  durationMin Int
  venue       String?

  invigilatorId String?
  invigilator   User?   @relation(fields: [invigilatorId], references: [id])
}

model HealthRecord {
  id        String  @id @default(cuid())
  studentId String  @unique
  student   Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  allergies        String?
  medications      String?
  bloodGroup       String?
  emergencyContact String?
  notes            String?

  updatedAt DateTime @updatedAt
}

model SystemSettings {
  id             String   @id @default(uuid())
  schoolName     String
  schoolAddress  String?
  schoolPhone    String?
  schoolEmail    String?
  website        String?
  logoUrl        String?
  academicYear   String?
  currentTerm    String?
  timezone       String?
  currency       String?
  setupCompleted Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model NewsArticle {
  id          String    @id @default(uuid())
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  title       String
  content     String
  excerpt     String?
  category    String
  imageUrl    String?
  tags        String?
  status      String    @default("DRAFT")
  publishDate DateTime?
  author      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
}

model Event {
  id          String    @id @default(uuid())
  tenantId    String?
  tenant      Tenant?   @relation(fields: [tenantId], references: [id])
  title       String
  description String?
  eventDate   DateTime
  endDate     DateTime?
  location    String?
  category    String
  imageUrl    String?
  status      String    @default("UPCOMING")
  attendees   String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([tenantId])
}


// --- Communication Hub ---

model Conversation {
  id            String   @id @default(cuid())
  tenantId      String?
  tenant        Tenant?  @relation(fields: [tenantId], references: [id])
  type          String   // 'DIRECT', 'GROUP'
  subject       String?  // For group chats or subject lines
  
  participants  ConversationParticipant[]
  messages      Message[]
  
  lastMessageAt DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([lastMessageAt])
}

model ConversationParticipant {
  id              String       @id @default(cuid())
  conversationId  String
  conversation    Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  userId          String
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  unreadCount     Int      @default(0)
  lastReadAt      DateTime @default(now())
  
  @@unique([conversationId, userId])
  @@index([userId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  
  content        String
  attachments    String?      // JSON string of attachment URLs/metadata
  
  readBy         MessageReadStatus[]
  
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([conversationId])
}

model MessageReadStatus {
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  readAt    DateTime @default(now())

  @@id([messageId, userId])
}

// --- Enterprise RBAC ---

model Role {
  id          String   @id @default(cuid())
  name        String
  description String?
  isSystem    Boolean  @default(false) // System roles cannot be deleted (e.g. ADMIN)
  
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id])
  
  users       User[]
  permissions RolePermission[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([tenantId, name])
}

model Permission {
  id          String   @id @default(cuid())
  slug        String   @unique // e.g. "users.create", "finance.view"
  description String?
  group       String   // e.g. "User Management", "Finance"
  
  roles       RolePermission[]
  users       UserPermission[]
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model RolePermission {
  roleId       String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  @@id([roleId, permissionId])
}

model UserPermission {
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  
  grantedBy    String?    // User ID
  grantedAt    DateTime   @default(now())

  @@id([userId, permissionId])
}

model AuditLog {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String?
  action      String
  resource    String
  resourceId  String?
  details     String? // JSON string
  ipAddress   String?
  userAgent   String?
  createdAt   DateTime @default(now())
  
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
  user        User?    @relation(fields: [userId], references: [id])

  @@index([tenantId, createdAt])
}

model AiInsight {
  id        String   @id @default(cuid())
  tenantId  String
  entityType String   // 'STUDENT', 'CLASS'
  entityId   String
  insight    String   // The text generated by AI
  createdAt  DateTime @default(now())
  expiresAt  DateTime? // Optional, for cache invalidation
  
  tenant     Tenant   @relation(fields: [tenantId], references: [id])

  @@index([tenantId, entityType, entityId])
}

model StudentApplication {
  id                String   @id @default(cuid())
  tenantId          String?
  firstName         String
  lastName          String
  dateOfBirth       DateTime
  gender            String
  parentName        String
  parentEmail       String
  parentPhone       String
  currentSchool     String?
  gradeApplying     String
  intendedStartDate DateTime
  status            String   @default("PENDING")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ClassSchedule {
  id        String  @id @default(cuid())
  tenantId  String?
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])
  teacherId String?
  teacher   TeacherProfile? @relation(fields: [teacherId], references: [id])
  dayOfWeek String  // "Monday", etc.
  startTime String  // "08:00"
  endTime   String  // "09:00"
  room      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
