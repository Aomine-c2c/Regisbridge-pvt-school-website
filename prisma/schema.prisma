generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  password    String
  firstName   String
  lastName    String
  role        String // SQLite doesn't support enums natively
  grade       String?
  studentId   String?   @unique
  phoneNumber String?
  status      String    @default("ACTIVE") // UserStatus
  permissions String? // Stored as JSON string
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  lastLoginAt DateTime?

  // Relations
  student         Student?
  teacherSubjects Subject[]     @relation("TeacherSubjects")
  classes         Class[]       @relation("ClassTeacher")
  staffProfile    StaffProfile?

  @@index([email])
  @@index([role])
  @@index([status])
}

model Student {
  id             String    @id @default(cuid())
  userId         String    @unique
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollmentDate DateTime  @default(now())
  currentGrade   String
  section        String?
  rollNumber     String    @unique
  parentName     String?
  parentEmail    String?
  parentPhone    String?
  address        String?
  dateOfBirth    DateTime?
  bloodGroup     String?
  medicalNotes   String?

  // Relations
  grades      Grade[]
  attendance  Attendance[]
  assignments AssignmentSubmission[]
  feePayments FeePayment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations to new modules
  libraryIssues LibraryIssue[]
  hostelBed     HostelBed?
  examResults   ExamResult[]

  @@index([currentGrade])
  @@index([rollNumber])
}

model Subject {
  id          String  @id @default(cuid())
  name        String
  code        String  @unique
  grade       String
  description String?
  teacherId   String?
  teacher     User?   @relation("TeacherSubjects", fields: [teacherId], references: [id], onDelete: SetNull)

  // Relations
  grades      Grade[]
  assignments Assignment[]
  classes     Class[] // If we want to link subjects to classes directly
  schedule    ClassSchedule[]

  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  ExamSchedule ExamSchedule[]

  @@index([grade])
  @@index([teacherId])
}

model Grade {
  id           String   @id @default(cuid())
  studentId    String
  student      Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subjectId    String
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  term         String
  academicYear String
  assessmentType String // 'EXAM', 'TEST', 'ASSIGNMENT', 'PROJECT'
  score        Float
  maxScore     Float
  percentage   Float
  letterGrade  String
  remarks      String?
  gradedBy     String
  gradedAt     DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, subjectId, term, academicYear])
  @@index([studentId, term])
  @@index([subjectId])
  @@index([academicYear])
}

model Attendance {
  id        String   @id @default(cuid())
  studentId String
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  date      DateTime
  status    String // AttendanceStatus
  notes     String?
  markedBy  String
  markedAt  DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([studentId, date])
  @@index([date])
  @@index([studentId, date])
  @@index([status])
}

model Assignment {
  id             String   @id @default(cuid())
  title          String
  description    String
  subjectId      String
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  grade          String
  dueDate        DateTime
  totalPoints    Int
  assignmentType String // AssignmentType
  status         String   @default("ACTIVE") // AssignmentStatus
  createdBy      String

  // Relations
  submissions AssignmentSubmission[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([subjectId])
  @@index([grade])
  @@index([dueDate])
  @@index([status])
  @@index([assignmentType])
}

model AssignmentSubmission {
  id           String     @id @default(cuid())
  assignmentId String
  assignment   Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  studentId    String
  student      Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  submittedAt  DateTime   @default(now())
  fileUrl      String?
  fileName     String?
  fileSize     Int?
  content      String?
  score        Float?
  feedback     String?
  gradedAt     DateTime?
  gradedBy     String?
  status       String     @default("SUBMITTED") // SubmissionStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([assignmentId, studentId])
  @@index([studentId])
  @@index([assignmentId])
  @@index([status])
}

model FeePayment {
  id            String    @id @default(cuid())
  studentId     String
  student       Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  amount        Float
  feeType       String // FeeType
  term          String
  academicYear  String
  status        String // PaymentStatus
  paymentDate   DateTime?
  paymentMethod String? // PaymentMethod
  receiptNumber String?   @unique
  transactionId String?
  dueDate       DateTime
  paidAmount    Float     @default(0)
  balance       Float
  notes         String?
  recordedBy    String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([studentId])
  @@index([status])
  @@index([dueDate])
  @@index([academicYear, term])
  @@index([receiptNumber])
  @@index([feeType])
}

model FinancialReport {
  id          String   @id @default(cuid())
  reportType  String // ReportType
  title       String
  periodStart DateTime
  periodEnd   DateTime
  periodLabel String

  // Balances stored as JSON string
  openingBalance String // Currency[]
  closingBalance String // Currency[]

  // Categories stored as JSON string
  income   String // IncomeCategory[]
  expenses String // ExpenseCategory[]

  // Totals stored as JSON string
  totalIncome   String // Currency[]
  totalExpenses String // Currency[]
  netPosition   String // Currency[]

  // Approval tracking
  status       String  @default("DRAFT") // ReportStatus
  approvalData String? // Approval signatures and dates (JSON string)

  // Metadata
  documentUrl String?
  notes       String?
  createdBy   String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([reportType])
  @@index([periodStart, periodEnd])
  @@index([status])
  @@index([createdBy])
}

model NewsArticle {
  id          String    @id @default(cuid())
  title       String
  content     String
  excerpt     String?
  author      String?
  publishDate DateTime?
  status      String    @default("DRAFT") // 'draft' | 'published' | 'archived'
  category    String // 'news' | 'announcement' | 'event'
  imageUrl    String?
  tags        String? // JSON string

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([category])
  @@index([publishDate])
}

model Event {
  id          String    @id @default(cuid())
  title       String
  description String
  eventDate   DateTime
  endDate     DateTime?
  location    String?
  category    String // 'academic' | 'sports' | 'cultural' | 'other'
  status      String    @default("UPCOMING") // 'upcoming' | 'ongoing' | 'completed' | 'cancelled'
  imageUrl    String?
  attendees   Int?      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([eventDate])
  @@index([category])
  @@index([status])
}

model Class {
  id           String  @id @default(cuid())
  name         String
  grade        String
  academicYear String
  teacherId    String?
  teacher      User?   @relation("ClassTeacher", fields: [teacherId], references: [id])

  subjects Subject[]
  schedule ClassSchedule[]

  description String?
  room        String?
  capacity    Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([name, grade, academicYear])
  @@index([teacherId])
  @@index([grade])
  @@index([academicYear])
}

model ClassSchedule {
  id        String  @id @default(cuid())
  classId   String
  class     Class   @relation(fields: [classId], references: [id], onDelete: Cascade)
  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  dayOfWeek String // "Monday", "Tuesday", etc.
  startTime String // "08:00" - HH:MM 24h format preferably
  endTime   String // "09:00"
  room      String? // Optional room override, otherwise use Class room or Subject default

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([classId])
  @@index([subjectId])
  @@index([dayOfWeek])
}

// --- Transport Module ---

model Vehicle {
  id                 String  @id @default(cuid())
  registrationNumber String  @unique
  capacity           Int
  model              String?
  status             String  @default("ACTIVE") // 'ACTIVE', 'MAINTENANCE', 'RETIRED'
  driverName         String?
  driverPhone        String?

  trips Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Route {
  id            String  @id @default(cuid())
  name          String
  startLocation String
  endLocation   String
  stops         String // JSON string of stops
  schedule      String? // JSON string or cron
  distance      Float?

  trips Trip[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Trip {
  id        String    @id @default(cuid())
  routeId   String
  route     Route     @relation(fields: [routeId], references: [id])
  vehicleId String
  vehicle   Vehicle   @relation(fields: [vehicleId], references: [id])
  date      DateTime
  startTime DateTime
  endTime   DateTime?
  status    String    @default("SCHEDULED") // 'SCHEDULED', 'IN_PROGRESS', 'COMPLETED', 'CANCELLED'
  driverId  String? // Link to User if driver is a system user

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([routeId])
  @@index([vehicleId])
  @@index([date])
}

// --- Library Module ---

model Book {
  id              String  @id @default(cuid())
  title           String
  author          String
  isbn            String? @unique
  category        String?
  publisher       String?
  publicationYear Int?
  copies          Int     @default(1)
  available       Int     @default(1)
  location        String? // Shelf number
  status          String  @default("AVAILABLE") // 'AVAILABLE', 'OUT_OF_STOCK', 'LOST'

  issues LibraryIssue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model LibraryIssue {
  id         String    @id @default(cuid())
  bookId     String
  book       Book      @relation(fields: [bookId], references: [id])
  studentId  String
  student    Student   @relation(fields: [studentId], references: [id])
  issueDate  DateTime  @default(now())
  dueDate    DateTime
  returnDate DateTime?
  status     String    @default("ISSUED") // 'ISSUED', 'RETURNED', 'OVERDUE'
  fineAmount Float     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookId])
  @@index([studentId])
  @@index([status])
}

// --- Hostel Module ---

model HostelBlock {
  id       String  @id @default(cuid())
  name     String
  type     String // 'BOYS', 'GIRLS', 'STAFF'
  capacity Int
  wardenId String?

  rooms HostelRoom[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model HostelRoom {
  id         String      @id @default(cuid())
  blockId    String
  block      HostelBlock @relation(fields: [blockId], references: [id], onDelete: Cascade)
  roomNumber String
  capacity   Int
  floor      Int

  beds HostelBed[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([blockId])
}

model HostelBed {
  id        String     @id @default(cuid())
  roomId    String
  room      HostelRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  bedNumber String
  studentId String?    @unique
  student   Student?   @relation(fields: [studentId], references: [id])
  status    String     @default("VACANT") // 'VACANT', 'OCCUPIED', 'MAINTENANCE'

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([roomId])
}

// --- Exams Module ---

model ExamSession {
  id           String   @id @default(cuid())
  name         String // e.g. "Term 1 Finals 2024"
  academicYear String
  term         String
  startDate    DateTime
  endDate      DateTime
  status       String   @default("UPCOMING") // 'UPCOMING', 'ACTIVE', 'COMPLETED', 'PUBLISHED'

  schedules ExamSchedule[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ExamSchedule {
  id              String      @id @default(cuid())
  sessionId       String
  session         ExamSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  subjectId       String
  subject         Subject     @relation(fields: [subjectId], references: [id])
  date            DateTime
  startTime       String
  durationMinutes Int
  venue           String?
  invigilatorId   String? // Link to User (Staff)

  results ExamResult[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([sessionId])
  @@index([subjectId])
  @@index([date])
}

model ExamResult {
  id            String       @id @default(cuid())
  scheduleId    String
  schedule      ExamSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)
  studentId     String
  student       Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)
  marksObtained Float
  maxMarks      Float
  grade         String?
  remarks       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([scheduleId])
  @@index([studentId])
}

// --- HR Module ---

model StaffProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId      String   @unique // Added for staff registration/identification
  designation     String
  department      String
  joinDate        DateTime
  qualification   String?
  experienceYears Int?
  basicSalary     Float
  contractType    String // 'PERMANENT', 'CONTRACT', 'PART_TIME'

  payrolls Payroll[]
  leaves   Leave[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Payroll {
  id          String       @id @default(cuid())
  staffId     String
  staff       StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  month       Int
  year        Int
  basicSalary Float
  allowances  Float        @default(0)
  deductions  Float        @default(0)
  netSalary   Float
  status      String       @default("DRAFT") // 'DRAFT', 'PROCESSED', 'PAID'
  paymentDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffId])
  @@index([month, year])
}

model Leave {
  id         String       @id @default(cuid())
  staffId    String
  staff      StaffProfile @relation(fields: [staffId], references: [id], onDelete: Cascade)
  type       String // 'SICK', 'CASUAL', 'ANNUAL', 'UNPAID'
  startDate  DateTime
  endDate    DateTime
  reason     String
  status     String       @default("PENDING") // 'PENDING', 'APPROVED', 'REJECTED'
  approvedBy String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([staffId])
  @@index([status])
}

model SystemSettings {
  id            String   @id @default(cuid())
  schoolName    String
  schoolAddress String?
  schoolPhone   String?
  schoolEmail   String?
  website       String?
  logoUrl       String?
  
  academicYear  String?
  currentTerm   String?
  
  timezone      String?  @default("UTC")
  currency      String?  @default("USD")
  
  setupCompleted Boolean @default(false)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model StudentApplication {
  id              String   @id @default(cuid())
  firstName       String
  lastName        String
  dateOfBirth     DateTime
  gender          String
  
  parentName      String
  parentEmail     String
  parentPhone     String
  
  currentSchool   String?
  gradeApplying   String
  intendedStartDate DateTime
  
  status          String   @default("PENDING") // 'PENDING', 'REVIEWED', 'APPROVED', 'REJECTED'
  notes           String?
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([status])
  @@index([gradeApplying])
}
